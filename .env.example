# Supabase — get from your project dashboard → Settings → API
# On Vercel these are already set; locally run `vercel env pull .env.local`.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to the browser (reserved for the lock-down sprint)
SUPABASE_SERVICE_ROLE_KEY=

# AI caption drafting — server-side only, never exposed to the browser.
# The Draft button works with NO key (free local templates). Add either key to
# upgrade to real AI. Gemini's free tier needs no credit card.
#   Claude:  https://console.anthropic.com → API Keys (paid credits)
#   Gemini:  https://aistudio.google.com/apikey (free tier, no card)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# App URL (used for redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
